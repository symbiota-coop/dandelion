<div style="height: 420px">
  <canvas id="canvas-<%= r = SecureRandom.uuid %>"></canvas>
</div>

<script>
  $(function () {
    Chart.register(ChartDataLabels);

    var labels = <%== chart_labels.to_json %>;
    var breakdownValues = <%== chart_breakdown_values.to_json %>;
    var breakdownLabels = <%== chart_breakdown_labels.to_json %>;
    var breakdownColors = <%== chart_breakdown_colors.to_json %>;
    var actualData = <%== chart_actual_values.to_json %>;
    var projectionData = <%== chart_projection_values.to_json %>;
    var averageData = <%== chart_average_values.to_json %>;
    var totalData = actualData.map(function (actual, index) {
      return (actual || 0) + (projectionData[index] || 0);
    });

    function formatCurrency(value) {
      return '£' + Math.round(value || 0).toLocaleString();
    }

    var datasets = Object.keys(breakdownValues).map(function (key) {
      return {
        type: 'bar',
        label: breakdownLabels[key] || key,
        backgroundColor: breakdownColors[key] || 'rgba(0, 175, 94, 0.92)',
        borderColor: breakdownColors[key] || 'rgba(0, 175, 94, 1)',
        borderWidth: 1,
        borderRadius: 4,
        data: breakdownValues[key],
        stack: 'contributions'
      };
    });

    datasets.push({
      type: 'bar',
      label: 'Projected remainder',
      backgroundColor: 'rgba(0, 175, 94, 0.28)',
      borderColor: 'rgba(0, 175, 94, 0.45)',
      borderWidth: 1,
      borderRadius: 4,
      data: projectionData,
      stack: 'contributions'
    });

    datasets.push({
      type: 'line',
      label: 'Monthly total',
      data: totalData,
      borderColor: 'rgba(0, 0, 0, 0)',
      backgroundColor: 'rgba(0, 0, 0, 0)',
      pointRadius: 0,
      pointHoverRadius: 0,
      hitRadius: 0,
      fill: false,
      stack: 'total_labels',
      yAxisID: 'y',
      datalabels: {
        display: true,
        color: '#252a2e',
        anchor: 'end',
        align: 'top',
        offset: 4,
        clamp: true,
        clip: false,
        font: {
          weight: 'bold',
          size: 11
        },
        formatter: function(value) {
          return value ? formatCurrency(value) : null;
        }
      }
    });

    datasets.push({
      type: 'line',
      label: '3-month average',
      data: averageData,
      borderColor: 'rgba(255, 193, 7, 1)',
      backgroundColor: 'rgba(255, 193, 7, 0.15)',
      pointBackgroundColor: 'rgba(255, 193, 7, 1)',
      pointRadius: 3,
      tension: 0.25,
      fill: false,
      stack: 'average_line',
      yAxisID: 'y'
    });

    new Chart(document.getElementById("canvas-<%= r %>").getContext("2d"), {
      data: {
        labels: labels,
        datasets: datasets
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: {
            position: 'bottom',
            labels: {
              filter: function(item) {
                return item.text !== 'Monthly total';
              }
            }
          },
          tooltip: {
            filter: function(context) {
              return context.dataset.label !== 'Monthly total';
            },
            callbacks: {
              label: function(context) {
                if (context.dataset.type === 'line') {
                  return context.dataset.label + ': ' + formatCurrency(context.parsed.y);
                }

                var actual = actualData[context.dataIndex] || 0;
                var projected = projectionData[context.dataIndex] || 0;
                var isProjection = context.dataset.label === 'Projected remainder';
                var value = isProjection ? actual + projected : context.parsed.y;
                var label = isProjection ? 'Projected total' : context.dataset.label;
                return label + ': ' + formatCurrency(value);
              }
            }
          },
          datalabels: {
            display: function(context) {
              var value = context.dataset.data[context.dataIndex] || 0;
              if (context.dataset.label === 'Monthly total') {
                return value > 0;
              }
              return context.dataset.type !== 'line' && value >= 500;
            },
            color: 'white',
            font: {
              weight: 'bold'
            },
            formatter: function(value, context) {
              if (context.dataset.label === 'Monthly total') {
                return formatCurrency(value);
              }
              if (context.dataset.label === 'Projected remainder') {
                return '+' + formatCurrency(value);
              }
              return formatCurrency(value);
            }
          }
        },
        layout: {
          padding: {
            top: 24
          }
        },
        scales: {
          x: {
            stacked: true
          },
          y: {
            stacked: true,
            beginAtZero: true,
            grace: '12%',
            ticks: {
              callback: function(value) {
                return formatCurrency(value);
              }
            }
          }
        }
      }
    });
  });
</script>
