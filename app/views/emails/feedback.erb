<div class="main">
  <%= EmailHelper.replace_youtube_oembeds(
        EmailFields.replace_magic_tags(
          event.feedback_email_body || event.organisation.feedback_email_body,
          event: event,
          recipient_variables: true,
          event_name: "<a href='#{ENV['BASE_URI']}/e/#{event.slug}'>#{event.name}</a>"
        )
        .gsub('[feedback_url]', "#{ENV['BASE_URI']}/events/#{event.id}/give_feedback?token=%recipient.feedback_token%")
      ) %>
</div>
<div class="footer">
  <a href="<%= ENV['BASE_URI'] %>/accounts/subscriptions?sign_in_token=%recipient.token%">Opt out of requests for feedback</a>
</div>
