<div class="main">
  <p>Hi %recipient.firstname%,</p>
  <p>
    <%= account.name %> joined the waitlist for
    <% if defined?(ticket_type) && ticket_type %>
      <%= ticket_type.name %> tickets for <%= event.name %>
    <% else %>
      <%= event.name %>
    <% end %>
  </p>
  <p>
    <% if defined?(ticket_type) && ticket_type %>
      <a href="<%= ENV['BASE_URI'] %>/events/<%= event.id %>/ticket_type_waitlists?sign_in_token=%recipient.token%">View waitlist</a>
    <% else %>
      <a href="<%= ENV['BASE_URI'] %>/events/<%= event.id %>/waitlist?sign_in_token=%recipient.token%">View waitlist</a>
    <% end %>
  </p>
</div>
