<% Event.trending(limit: 3).each { |event| %>
<div class="mb-1">
  <%= cp(:'events/block_carousel', locals: { event: event }, event: event, key: "/events/#{event.id}/block_carousel?organisation_id=#{@organisation.try(:id)}&timezone=#{current_account ? current_account.time_zone : session[:time_zone]}") %>
</div>
<% }  %>
<p class="mt-3 mb-0"><a href="/events?order=trending">More trending &rarr;</a></p>
