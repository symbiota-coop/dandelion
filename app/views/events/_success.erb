<% @theme_color ||= resolved_event_theme_color(@event) %>
<div class="card shadow-sm">
  <h3 class="card-header bg-primary text-white">Thanks for booking onto <%= @event.name %>!</h3>
  <div class="card-body readable">

    <p>
      <a target="_blank" href="/orders/<%=@order.id%>" class="btn btn-outline-primary">
        View confirmation <% unless @event.no_tickets_pdf? %>and <%= @order.tickets.count == 1 ? 'ticket' : 'tickets' %><% end %>
        <i class="bi bi-qr-code"></i>
      </a>
    </p>

    <p>
      We've also sent the confirmation via email. If you don't see anything in your inbox, please check your spam folder.
    </p>

    <% if @event.redirect_url %>
      <p>Redirecting you to <a href="<%= @event.redirect_url %>"><%= @event.redirect_url %></a>&hellip; <i class="bi bi-spin bi-slash-lg"></i></p>
      <script>
        $(function () {
          setTimeout(function () {
            window.location = '<%= @event.redirect_url %>'
          }, 3000)
        })
      </script>
    <% else %>


      <% unless @event.evergreen? %>
        <script>
          function showSavedTooltipAndSubmit(element) {
            // Create tooltip if it doesn't exist
            if (!$(element).data('bs.tooltip')) {
              $(element).tooltip({
                title: 'Saved!',
                trigger: 'manual',
                placement: 'top'
              });
            }

            // Show tooltip
            $(element).tooltip('show');

            // Hide and submit
            setTimeout(function() {
              $(element).tooltip('hide');
              $(element.form).submit();
            }, 500);
          }
        </script>
        <p class="mb-3">
          <strong>
            If you booked
            <%= @order.tickets.count == 1 ? 'the ticket' : 'tickets' %>
            for someone else, you're welcome to let us know the
            <%= @order.tickets.count == 1 ? 'name and email address of the ticketholder' : 'names and email addresses of ticketholders' %>
            so they hear about any important updates to the event (we won't use these details for anything else):</strong></p>
        <div class="mb-3">
          <% @order.tickets.each_with_index { |ticket,i| %>
          <div class="alert alert-success ticket">
            <h4 class="mb-2">
              <i class="bi bi-ticket-detailed-fill"></i>
              <%=ticket.ticket_type.try(:name)%>
            </h4>
            <div class="row">
              <div class="col-6">
                <div data-pagelet-url="/events/<%=@event.id%>/orders/<%=@order.id%>/ticketholders/<%=ticket.id%>/name" data-pagelet-no-opacity-change="true">
                  <%= partial :"events/ticketholder_name", locals: { ticket: ticket } %>
                </div>
              </div>
              <div class="col-6">
                <div data-pagelet-url="/events/<%=@event.id%>/orders/<%=@order.id%>/ticketholders/<%=ticket.id%>/email?success=<%=params[:success] ? 1 : 0 %>" data-pagelet-no-opacity-change="true">
                  <%= partial :"events/ticketholder_email", locals: { ticket: ticket, success: (params[:success] ? 1 : 0) } %>
                </div>
              </div>
            </div>
          </div>
          <% } %>
        </div>
      <% end %>

      <% if @event.organisation&.affiliate_credit_percentage %>
        <% affiliate_link = "#{ENV['BASE_URI']}/e/#{@event.slug}?affiliate_type=Account&affiliate_id=#{@order.account_id}" %>
        <p>
          <a href="<%= affiliate_link %>">Here's your affiliate link for this event.</a>
          For each order made via this link,
          you receive credit towards future events equal to <%= @event.organisation.affiliate_credit_percentage %>% of the order value.
        </p>
        <div class="mb-3">
          <h5>Share your link</h5>
          <%= partial :share, locals: { share_url: affiliate_link } %>
        </div>
      <% end %>

      <% if (@event.start_time && @event.end_time) || @event.event_sessions.exists? %>
        <p class="mb-1"><strong>Add to calendar</strong></p>
        <p class="mb-1"><% if @event.event_sessions.exists? %>Full event: <% end %><%= partial :'events/add_to_calendar', locals: { event: @event } %></p>
        <% @event.event_sessions.each do |event_session| %>
          <p class="mb-1">Session <%= event_session.session_number %>: <%= partial :'events/add_to_calendar', locals: { event_session: event_session } %></p>
        <% end %>
      <% end %>

      <iframe
      id="circles"
      src="https://circles.gnosis.io/pilots/kudos-ga?group=dandelion&text=v2&address=0xC067cAd5F4A0c4652866371b723483f83B1ED0aA&theme_color=<%= CGI.escape(@theme_color || '') %>"
      style="width: 100%; border: 0;"      
      loading="lazy">
      </iframe>
      <script src="//cdnjs.cloudflare.com/ajax/libs/iframe-resizer/4.2.10/iframeResizer.min.js"></script>
      <script>
        $(function () {
          $('#circles').iFrameResize({log: true, checkOrigin: false, heightCalculationMethod : 'taggedElement'})
        })
      </script>

    <% end %>
  </div>
</div>
