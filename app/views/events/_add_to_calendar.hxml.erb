<%
if defined?(event)
  addable = event
elsif defined?(event_session)
  addable = event_session
end

name = addable.name
details = "#{ENV['BASE_URI']}/e/#{addable.slug}"
location = addable.location
start_time = addable.start_time.utc.iso8601.gsub('-', '').gsub(':', '')
end_time = addable.end_time.utc.iso8601.gsub('-', '').gsub(':', '')
google_cal_url = "https://www.google.com/calendar/render?action=TEMPLATE&text=#{ERB::Util.url_encode(name)}&details=#{ERB::Util.url_encode(details)}&location=#{ERB::Util.url_encode(location)}&dates=#{ERB::Util.url_encode("#{start_time}/#{end_time}")}"
%>
<view style="InfoTableRow">
  <text style="InfoTableLabel">Add to calendar</text>
  <view style="InfoTableValue">
    <view style="CalendarLinks">
      <text style="InfoTableLink" href="<%= google_cal_url %>" action="deep-link">Google</text>
      <text style="CalendarSeparator"> · </text>
      <text style="InfoTableLink" href="<%= ENV['BASE_URI'] %>/<%= addable.class.name.underscore.pluralize %>/<%= addable.id %>/ics" action="deep-link">ICS</text>
    </view>
  </view>
</view>
