<a class="btn btn-primary mb-3" href="/o/<%= @organisation.slug %>/events">All events</a>
<% if organisation_assistant? || @organisation.allow_event_submissions %>
  <a class="btn btn-primary mb-3" href="/events/new?organisation_id=<%= @organisation.id %>">
    <% if organisation_assistant? %>
      Create an event
    <% else %>
      Submit an event for review
    <% end %>
  </a>
<% end %>
<% events = @events.paginate(page: params[:events_page], per_page: 10) %>
<%= partial :'events/blocks', locals: { events: events } %>
<div class="mt-3">
  <%= will_paginate events, param_name: 'events_page', page_links: false, renderer: WillPaginate::ViewHelpers::BootstrapRenderer %>
</div>