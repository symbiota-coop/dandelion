<%
  node_min_width = 10
  node_max_width = 20*node_min_width
  node_width_scale = 20
  edge_min_opacity = 0.25
  edge_opacity_scale = 1000
  color = '#00AF5E'

  organisation_edges = OrganisationEdge.and(:mutual_followers.gte => Padrino.env == :development ? 1 : 10).to_a
  org_ids = organisation_edges.flat_map { |edge| [edge.source_id, edge.sink_id] }.uniq
  organisations = Organisation.and(:id.in => org_ids)
  edges_by_source = organisation_edges.group_by(&:source_id)

  elements = []

  organisations.each do |organisation|
    w = organisation.followers_count
    elements << {
      data: {
        id: organisation.id.to_s,
        slug: organisation.slug,
        name: CGI.unescapeHTML(Sanitize.fragment(organisation.name)),
        weight: w,
        width: [node_min_width + w.to_f / node_width_scale, node_max_width].min,
        color: color
      }
    }

    (edges_by_source[organisation.id] || []).each do |edge|
      w = edge.mutual_followers
      elements << {
        data: {
          id: edge.id.to_s,
          source: edge.source_id.to_s,
          target: edge.sink_id.to_s,
          weight: w,
          color: color,
          opacity: edge_min_opacity + w.to_f / edge_opacity_scale
        }
      }
    end
  end
%>

<%= partial :network_script, locals: {
  elements: elements.to_json,
  tap_handler: "window.open('/o/' + this.data('slug'), '_blank');"
} %>