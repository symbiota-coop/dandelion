<div class="row no-gutters mb-3">
  <div class="col">
    <script>
      $(function () {
        $('#activities_form').submit(function () {
          var url = '/o/<%= @organisation.slug %>/activities?' + $.param({q: $('input[name=q]', this).val()})
          $(this).closest('[data-pagelet-url]').attr('data-pagelet-url', url)
        })
      })
    </script>
    <% form_tag '', id: 'activities_form', class: 'mx-2 no-submit form-inline' do %>
      <div class="input-group">
        <%= text_field_tag :q, class: 'form-control', value: params[:q] %>
        <div class="input-group-append">
          <button class="btn btn-primary"><i class="bi bi-search"></i></button>
        </div>
      </div>
    <% end %>
  </div>
  <div class="col-12 ml-2 mt-3 col-lg-auto ml-lg-0 mt-lg-0">
    <% if organisation_admin? %>
      <a class="btn btn-primary mr-2" href="/activities/new?organisation_id=<%= @organisation.id %>">Create an activity</a>
    <% end %>
  </div>
</div>
<% activities = @activities.paginate(page: params[:page], per_page: 12) %>
<%= partial :'activities/blocks', locals: { activities: activities } %>
<div class="mt-3">
  <%= will_paginate activities, page_links: false, renderer: WillPaginate::ViewHelpers::BootstrapRenderer %>
</div>
<% if @inactive_activities&.exists? %>
  <a class="btn btn-secondary" href="javascript:;" onclick="$(this).hide().next().show()">Show <%= pluralize(@inactive_activities.count, 'inactive activity') %></a>
  <div style="display: none">
    <h3 class="mt-3">Inactive activities</h3>
    <%= partial :'activities/blocks', locals: { activities: @inactive_activities.order('name asc') } %>
  </div>
<% end %>
<% if organisation_admin? %>
  <% if (locked_activities = @organisation.activities.and(locked: true).order('name asc')).exists? %>
    <a class="btn btn-secondary" href="javascript:;" onclick="$(this).hide().next().show()">Show <%= pluralize(locked_activities.count, 'locked activity') %></a>
    <div style="display: none">
      <h3 class="mt-3">Locked activities</h3>
      <%= partial :'activities/blocks', locals: { activities: locked_activities } %>
    </div>
  <% end %>
<% end %>
