<div class="quick-theme-colors mb-3 d-flex flex-wrap align-items-center" data-input-name="<%= input_name %>">
  <% quick_colors.each do |color| %>
    <button type="button" class="quick-color-btn rounded-circle border p-0 mr-2 mb-1" style="width: 26px; height: 26px; background: <%= color %>; --ring-color: <%= color %>" data-color="<%= color %>" title="<%= color %>"></button>
  <% end %>
</div>
