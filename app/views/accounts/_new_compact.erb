<% unless @minimal_subscribe %>
  <a href="javascript:;" onclick="$(this).hide().next().show().find('input[type=text]').first().focus()" class="btn btn-primary mb-3">Subscribe</a>
<% end %>
<div class="text-left <% unless @minimal_subscribe %>card shadow-sm mb-3 <% end %>" <% unless @minimal_subscribe %> style="display: none"<% end %>>
  <% unless @minimal_subscribe %>
    <div class="card-header text-white bg-primary">
      <h4 class="my-0">
        <% %w{organisation activity local_group event}.each { |r| if instance_variable_get("@#{r}") %>
        Get email updates from <%= instance_variable_get("@#{r}").name %>
        <% if instance_variable_get("@#{r}").respond_to?(:organisation) %>
          and <%= instance_variable_get("@#{r}").organisation.name %>
        <% end %>
        <% break; end; } %>
      </h4>
    </div>
  <% end %>
  <script>
    $(function () {

      $('#new-account-form').submit(function () {
        if (!grecaptcha || grecaptcha.getResponse().length == 0) {
          alert('Please confirm you are not a robot');
          return false
        }
      })

    $("[name='account[country]']").select2({
      theme: 'bootstrap4',
      placeholder: 'Country',
      allowClear: true,
      width: '100%'
    })

    <% if @minimal_subscribe %>
    $('#new-account-form input[type=text]').first().focus()
    <% end %>

    })
  </script>
  <div class="<% unless @minimal_subscribe %> card-body <% end %>">
    <% form_tag '/accounts/new', { id: 'new-account-form' }.merge(@minimal_subscribe ? { target: '_blank' } : {}) do |f| %>
      <% %w{organisation activity local_group event}.each { |r| %>
      <% if instance_variable_get("@#{r}") %>
        <%= hidden_field_tag :"#{r}_id", value: instance_variable_get("@#{r}").id %>
      <% end %>
      <% } %>
      <%= text_field_tag :'account[name]', class: 'form-control mr-1 mb-1', required: true, placeholder: 'Name' %>
      <%= email_field_tag :'account[email]', class: 'form-control mr-1 mb-1', required: true, placeholder: 'Email' %>
      <%= text_field_tag :'account[postcode]', class: 'form-control mr-1 mb-1', placeholder: 'Postcode' %>
      <%= select_tag :'account[country]', class: 'mr-1', placeholder: 'Country', options: (['',''] + Account.countries) %>
      <div class="g-recaptcha" style="margin-bottom: 4px" data-sitekey="<%= ENV['RECAPTCHA_SITE_KEY'] %>"></div>
      <%= submit_tag 'Subscribe', class: 'btn d-block d-lg-inline btn-primary mb-1' %>
    <% end %>
  </div>
</div>
