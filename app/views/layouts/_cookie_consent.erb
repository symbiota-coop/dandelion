<div id="cookie-consent" class="cookie-consent d-none" role="dialog" aria-live="polite" aria-label="Cookie preferences">
  <div class="cookie-consent__copy">
    <h2>Cookies on Dandelion</h2>
    <p>Dandelion requires a few necessary cookies. We only use other cookies if you allow them.</p>
    <p>
      <a href="/cookies">Cookie policy</a>
      <span aria-hidden="true">&middot;</span>
      <a href="/privacy">Privacy policy</a>
    </p>
  </div>
  <div class="cookie-consent__settings d-none">
    <label><input type="checkbox" checked disabled> Necessary</label>
    <label><input type="checkbox" data-cookie-choice="analytics"> Analytics</label>
    <label><input type="checkbox" data-cookie-choice="marketing"> Marketing</label>
  </div>
  <div class="cookie-consent__actions">
    <button type="button" class="btn btn-outline-primary" data-cookie-action="reject">Necessary only</button>
    <button type="button" class="btn btn-outline-primary" data-cookie-action="customize">Customise</button>
    <button type="button" class="btn btn-outline-primary" data-cookie-action="save">Save choices</button>
    <button type="button" class="btn btn-primary" data-cookie-action="accept">Accept all</button>
  </div>
</div>
