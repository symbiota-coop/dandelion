<% if @organisation && @organisation.plausible_analytics_domain %>
  <script type="text/plain" data-cookie-category="analytics" defer data-domain="<%= @organisation.plausible_analytics_domain %>" src="https://plausible.io/js/script.pageview-props.revenue.tagged-events.js"></script>
  <script type="text/plain" data-cookie-category="analytics">
    window.plausible = window.plausible || function() { (window.plausible.q = window.plausible.q || []).push(arguments) }
  </script>
  <% if track_purchase? %>
    <script type="text/plain" data-cookie-category="analytics">
      plausible('Purchase', {
        props: { order_id: <%== purchase_analytics[:order_id].to_json %> },
        revenue: {
          currency: <%== purchase_analytics[:currency].to_json %>,
          amount: <%== purchase_analytics[:value].to_json %>
        }
      });
    </script>
  <% end %>
<% end %>

<% if @organisation && @organisation.simple_analytics_domain %>
  <script type="text/plain" data-cookie-category="analytics">
    window.sa_event=window.sa_event||function(){var a=[].slice.call(arguments);window.sa_event.q?window.sa_event.q.push(a):window.sa_event.q=[a]};
  </script>
  <script type="text/plain" data-cookie-category="analytics" async data-hostname="<%= @organisation.simple_analytics_domain %>" src="https://scripts.simpleanalyticscdn.com/latest.js"></script>
  <% if track_purchase? %>
    <script type="text/plain" data-cookie-category="analytics">
      sa_event('purchase', <%== simple_analytics_purchase_params.to_json %>);
    </script>
  <% end %>
<% end %>

<% if (pixel_ids = facebook_pixel_ids).any? %>
  <%= partial :'layouts/facebook_pixel', locals: { pixel_ids: pixel_ids } %>
<% end %>
