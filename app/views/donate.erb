<% if params[:thanks] %>
  <div class="row justify-content-center">
    <div class="col-lg-8">
      <div class="card my-4">
        <div class="card-body p-4">
          <p class="lead mb-3">
            <mark>Thank you so much for donating!</mark> 🎉
          </p>
          <p class="mb-0">
            Every contribution, no matter the size, helps us grow this co-op run platform. Thank you for believing in Dandelion!
          </p>
        </div>
      </div>
    </div>
  </div>

<% else %>

  <% account = current_account || (params[:account_id] && Account.find(params[:account_id])) %>
  <div class="row justify-content-center">
    <div class="col-lg-8">
      <div class="card my-4">
        <div class="card-body p-4">
          <% if account&.stripe_subscription_id %>
            <p class="mb-0">Thanks for making a <a href="https://billing.stripe.com/p/login/14kg1O9HD49fg2kcMM">monthly contribution</a> to Dandelion!</p>
          <% else %>
            <%= partial :'accounts/pay', locals: { account: account, source: params[:event_feedback_id] ? "event_feedback:#{params[:event_feedback_id]}" : 'donate', force: true } %>
          <% end %>

          <% if !params[:event_feedback_id] %>
            <iframe
          id="circles"
          src="https://circles.gnosis.io/pilots/kudos-ga?group=dandelion&text=v2&address=0xC067cAd5F4A0c4652866371b723483f83B1ED0aA&theme_color=<%= CGI.escape(@theme_color || '') %>"
          style="width: 100%; border: 0;"      
          loading="lazy">
            </iframe>
            <script src="//cdnjs.cloudflare.com/ajax/libs/iframe-resizer/4.2.10/iframeResizer.min.js"></script>
            <script>
              $(function () {
                $('#circles').iFrameResize({log: true, checkOrigin: false, heightCalculationMethod : 'taggedElement'})
              })
            </script>
          <% end %>
        </div>
      </div>

      <% if params[:event_feedback_id] %>
        <div class="row justify-content-center">
          <div class="col-lg-8">
            <%= partial :badges %>
          </div>
        </div>
      <% end %>
    </div>
  </div>

<% end %>
