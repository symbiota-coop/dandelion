<!-- Base Layout -->
<style id="Body" backgroundColor="#FFFFFF" flex="1" />

<!-- Events Section -->
<style id="EventsSection" paddingHorizontal="24" paddingTop="24" />

<!-- Event Card -->
<style id="EventCard" backgroundColor="#FFFFFF" borderRadius="16" marginBottom="16" overflow="hidden" shadowColor="#000000" shadowOpacity="0.1" shadowRadius="8" shadowOffsetX="0" shadowOffsetY="4">
  <modifier pressed="true">
    <style shadowOpacity="0.2" />
  </modifier>
</style>
<style id="EventImage" width="100%" height="180" borderTopLeftRadius="16" borderTopRightRadius="16" />
<style id="EventContent" padding="16" />
<style id="EventTitle" fontSize="16" fontWeight="600" color="#212529" marginBottom="4" />
<style id="EventDate" fontSize="14" color="#00B963" marginBottom="4" />
<style id="EventLocation" fontSize="14" color="#6c757d" />

<!-- Spinner / Loading -->
<style id="SpinnerContainer" flex="1" height="100" justifyContent="center" alignItems="center" paddingVertical="32" />
