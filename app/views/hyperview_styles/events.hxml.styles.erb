<!-- Event Detail Image -->
<style id="EventDetailImage" width="100%" height="240" />

<!-- Event Header -->
<style id="EventDetailHeader" paddingHorizontal="24" paddingTop="24" paddingBottom="8" />
<style id="EventDetailTitle" fontSize="24" fontWeight="700" color="#212529" lineHeight="32" />

<!-- Event Details Section -->
<style id="EventDetails" marginHorizontal="16" marginBottom="16" backgroundColor="#FFFFFF" borderRadius="12" borderWidth="1" borderColor="#E8E8E8" />
<style id="EventDetailRow" flexDirection="row" paddingVertical="12" paddingHorizontal="16" borderBottomWidth="1" borderBottomColor="#F0F0F0" alignItems="center">
  <modifier pressed="true">
    <style backgroundColor="#F5F5F5" />
  </modifier>
</style>
<style id="CalendarDateImage" width="48" height="48" marginRight="12" />
<style id="EventDetailIconImage" width="48" height="48" marginRight="12" />
<style id="EventDetailContent" flex="1" />
<style id="EventDetailPrimary" fontSize="15" fontWeight="600" color="#212529" />
<style id="EventDetailSecondary" fontSize="13" color="#6c757d" marginTop="2" />
<style id="EventDetailLink" fontSize="14" color="#212529" />
<style id="SessionBadge" backgroundColor="#00B963" borderRadius="4" paddingHorizontal="8" paddingVertical="4" marginTop="6" alignSelf="flex-start" />
<style id="SessionBadgeText" fontSize="12" fontWeight="600" color="#FFFFFF" />
<style id="EventTagsRow" flexDirection="row" flexWrap="wrap" paddingVertical="12" paddingHorizontal="16" />
<style id="EventTag" backgroundColor="#00B963" borderRadius="4" paddingHorizontal="10" paddingVertical="6" marginRight="8" marginBottom="8" />
<style id="EventTagText" fontSize="12" fontWeight="500" color="#FFFFFF" />

<!-- Info Table -->
<style id="InfoTable" marginHorizontal="16" marginBottom="16" backgroundColor="#FFFFFF" borderRadius="12" borderWidth="1" borderColor="#E8E8E8" />
<style id="InfoTableRow" flexDirection="row" paddingVertical="14" paddingHorizontal="16" borderBottomWidth="1" borderBottomColor="#F0F0F0" alignItems="center">
  <modifier pressed="true">
    <style backgroundColor="#F5F5F5" />
  </modifier>
</style>
<style id="InfoTableLabel" width="120" fontSize="14" color="#6c757d" />
<style id="InfoTableValue" flex="1" />
<style id="InfoTableText" fontSize="14" color="#212529" />
<style id="InfoTableLink" fontSize="14" color="#00B963" />
<style id="InfoTableOrgRow" flexDirection="row" alignItems="center" />
<style id="CoHostRow" marginTop="8" />
<style id="InfoTableOrgImage" width="40" height="40" borderRadius="8" marginRight="10" />
<style id="InfoTableQR" width="50" height="50" />
<style id="CalendarLinks" flexDirection="row" alignItems="center" />
<style id="CalendarSeparator" fontSize="14" color="#6c757d" marginHorizontal="8" />

<!-- Attendee Image Wall -->
<style id="AttendeeImageWall" flexDirection="row" flexWrap="wrap" marginBottom="4" />
<style id="AttendeeAvatar" width="36" height="36" borderRadius="18" marginRight="-8" borderWidth="2" borderColor="#FFFFFF" />

<!-- Footer Padding -->
<style id="FooterPadding" height="48" />
