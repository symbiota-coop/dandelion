# Copy to .env.test for local development
RACK_ENV=test
# Error reporting in tests: use none to avoid external services (default if unset: read config/error_tracking.yml)
# ERROR_TRACKING_BACKEND=none
PORT=8020
BASE_URI=http://127.0.0.1:8020
SESSION_SECRET=session_secret_must_be_at_least_64_chars_xxxxxxxxxxxxxxxxxxxxxxx
DOMAIN=example.com
DEFAULT_CURRENCY=EUR
DEFAULT_TIME_ZONE=Europe/Stockholm
STRIPE_PK=pk_test
STRIPE_SK=sk_test
STRIPE_API_VERSION=2020-08-27
SKIP_TOURS=true