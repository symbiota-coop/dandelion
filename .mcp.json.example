{
  "mcpServers": {
    "sentry": {
      "type": "http",
      "url": "https://mcp.sentry.dev/mcp"
    },
    "dandelion": {
      "type": "http",
      "url": "https://dandelion.events/mcp"
    },
    "render": {
      "type": "http",
      "url": "https://mcp.render.com/mcp",
      "headers": {
        "Authorization": "Bearer $RENDER_AUTH_TOKEN"
      }
    },
    "MongoDB": {
      "type": "http",
      "url": "$MONGODB_MCP_URL",
      "headers": {
        "Authorization": "Bearer $MONGODB_MCP_TOKEN"
      }
    },
    "stripe": {
      "type": "http",
      "url": "https://mcp.stripe.com"
    },
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer $GITHUB_PAT"
      }
    },
    "cloudflare-api": {
      "type": "http",
      "url": "https://mcp.cloudflare.com/mcp"
    }
  }
}
